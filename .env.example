# ScribeShift — environment variables TEMPLATE
#
# Copy this file to `.env` (repo root) and fill in real values.
# NEVER commit `.env` — it is gitignored and holds live credentials.
# This template contains PLACEHOLDERS ONLY — no real keys.
#
# Contexts: server = Express (`server/`) + Vercel functions (`api/`) + Cloud Run
# worker (`server/worker.js`); client = Vite browser bundle (`VITE_` vars only).
# (Vercel injects VERCEL and VERCEL_GIT_COMMIT_SHA automatically — not set here.)

# ── Supabase ──────────────────────────────────────────────────────────────────
# Server-side project URL.
SUPABASE_URL=https://your-project-ref.supabase.co
# Service-role key — bypasses RLS. SERVER/WORKER ONLY. Never expose to the browser.
SUPABASE_SERVICE_KEY=your-service-role-key
# Anon key (server copy). NOTE: not currently read by server/worker code — the
# browser uses VITE_SUPABASE_ANON_KEY below. Kept for parity with deploy docs.
SUPABASE_ANON_KEY=your-anon-key
# Direct Postgres connection string — used ONLY by bin/run-migration.mjs to apply
# SQL migrations. Supabase dashboard → Project Settings → Database → Connection
# string (URI). Contains the DB password — keep it out of the browser/build.
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

# Client-side (Vite — bundled into the browser; MUST be the anon key, never service).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── AI generation ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# OpenAI — required for structured brand palette extraction (throw-on-use:
# absence does not block server boot; extraction will fail gracefully until set).
OPENAI_API_KEY=
# Optional: override the extraction model (default: gpt-5.5).
# OPENAI_EXTRACTION_MODEL=gpt-5.5

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=ScribeShift <no-reply@strideshift.ai>

# ── Security / sessions ───────────────────────────────────────────────────────
# Encrypts social OAuth tokens at rest (AES-256-GCM). Also the fallback for
# OAUTH_STATE_SECRET when that is unset.
CREDENTIAL_ENCRYPTION_KEY=your-32-byte-hex-key
# Signs OAuth state params. Falls back to CREDENTIAL_ENCRYPTION_KEY if unset.
OAUTH_STATE_SECRET=your-oauth-state-secret
# Shared secret guarding the Vercel cron endpoints (matches the Supabase Vault
# `cron_secret` used by the pg_cron jobs).
CRON_SECRET=your-cron-secret

# ── App URLs ──────────────────────────────────────────────────────────────────
# Public frontend origin (OAuth redirects, email links). Defaults to localhost:5173.
FRONTEND_URL=http://localhost:5173

# ── Social: LinkedIn ──────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# Must match the LinkedIn app's registered callback AND the server route.
LINKEDIN_REDIRECT_URI=http://localhost:4321/api/auth/linkedin/callback
# Optional — LinkedIn versioned API header (default 202605).
LINKEDIN_API_VERSION=202605

# ── Social: Twitter / X ───────────────────────────────────────────────────────
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret
TWITTER_REDIRECT_URI=http://localhost:4321/api/auth/twitter/callback

# ── Social: Facebook / Instagram ──────────────────────────────────────────────
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:4321/api/auth/facebook/callback
INSTAGRAM_REDIRECT_URI=http://localhost:4321/api/auth/instagram/callback

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=your-google-calendar-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=your-google-calendar-client-secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:4321/api/auth/google-calendar/callback

# ── Runtime tuning (optional) ─────────────────────────────────────────────────
# Cloud Run worker poll interval, ms (default 4000).
WORKER_POLL_MS=4000
# HTTP port (Express server defaults to 4321; the worker health server to 8080).
PORT=4321
